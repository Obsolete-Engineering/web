{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "arrowParens": "always",
  "bracketSpacing": true,
  "singleAttributePerLine": true,
  "sortImports": true,
  "sortPackageJson": true,
  "embeddedLanguageFormatting": "auto",
  "ignorePatterns": [".astro/**", "dist/**", "public/**"]
}
