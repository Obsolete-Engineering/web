{
  "name": "obsolete-web",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "lefthook install",
    "check": "astro check",
    "test:browser": "bun run build && playwright test",
    "lint": "oxlint src --deny-warnings",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt --write src astro.config.mjs package.json tsconfig.json",
    "format:check": "oxfmt --check src astro.config.mjs package.json tsconfig.json"
  },
  "dependencies": {
    "@astrojs/react": "6.0.1",
    "@remotion/player": "4.0.484",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "astro": "^7.0.6",
    "ogl": "^1.0.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.484"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
