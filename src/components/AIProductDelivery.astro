---
import { aiProductDeliveryCopy as copy } from '../copy';
---

<section
  class="ai-delivery"
  id="ai-product-delivery"
  aria-labelledby="ai-delivery-title"
  data-motion-section="ai-delivery"
>
  <div class="ai-delivery__inner">
    <header class="ai-delivery__header">
      <div class="ai-delivery__rail" data-motion="ai-delivery-copy">
        <p class="ai-delivery__eyebrow">
          <span aria-hidden="true"></span>
          {copy.eyebrow}
        </p>
        <p class="ai-delivery__audience">{copy.audience}</p>
      </div>

      <div class="ai-delivery__introduction">
        <h2 id="ai-delivery-title" data-motion="ai-delivery-copy">{copy.title}</h2>
        <div class="ai-delivery__position" data-motion="ai-delivery-copy">
          <p>{copy.introduction}</p>
          <p class="ai-delivery__principle">{copy.principle}</p>
        </div>
      </div>
    </header>

    <div class="ai-delivery__field" data-motion="ai-delivery-field">
      <section class="ai-delivery__outcomes" aria-labelledby="ai-delivery-outcomes-title">
        <h3 id="ai-delivery-outcomes-title">{copy.outcomesLabel}</h3>

        <ol>
          {
            copy.outcomes.map((outcome) => (
              <li class="ai-delivery__outcome" data-ai-outcome={outcome.id}>
                <a href="#ai-judgment-loop">
                  <p class="ai-delivery__outcome-label">
                    <span>{outcome.index}</span>
                    {outcome.label}
                  </p>
                  <h4>{outcome.title}</h4>
                  <p class="ai-delivery__outcome-description">{outcome.description}</p>
                  <p class="ai-delivery__outcome-action">
                    <span>{copy.outcomeAction}</span>
                    <span aria-hidden="true">↘</span>
                  </p>
                </a>
              </li>
            ))
          }
        </ol>

        <div class="ai-delivery__route" aria-hidden="true">
          {copy.outcomes.map(() => <span></span>)}
        </div>
      </section>

      <section
        class="ai-delivery__process"
        id="ai-judgment-loop"
        aria-labelledby="ai-delivery-process-title"
      >
        <header>
          <p>{copy.process.eyebrow}</p>
          <h3 id="ai-delivery-process-title">{copy.process.title}</h3>
        </header>

        <ol>
          {
            copy.process.steps.map((step) => (
              <li>
                <span>{step.index}</span>
                <h4>{step.title}</h4>
                <p>{step.description}</p>
              </li>
            ))
          }
        </ol>
      </section>

      <footer class="ai-delivery__footer">
        <p>{copy.scope}</p>
        <a href={copy.action.href}>
          <span>{copy.action.label}</span>
          <span aria-hidden="true">{copy.action.suffix}</span>
        </a>
      </footer>
    </div>
  </div>
</section>

<style>
  .ai-delivery {
    background: var(--color-neutral);
    border-bottom: 1px solid var(--color-line);
    color: var(--color-primary);
    padding: clamp(72px, 9vw, 128px) clamp(20px, 3.34vw, 48px);
  }

  .ai-delivery__inner {
    display: grid;
    gap: clamp(72px, 9vw, 128px);
    margin-inline: auto;
    max-width: 1344px;
  }

  .ai-delivery__header {
    display: grid;
    gap: clamp(64px, 8vw, 112px);
  }

  .ai-delivery__rail,
  .ai-delivery__eyebrow,
  .ai-delivery__outcome-label,
  .ai-delivery__outcome-action,
  .ai-delivery__footer,
  .ai-delivery__footer a {
    align-items: center;
    display: flex;
  }

  .ai-delivery__rail {
    justify-content: space-between;
  }

  .ai-delivery__eyebrow,
  .ai-delivery__audience,
  .ai-delivery__outcomes > h3,
  .ai-delivery__process header > p {
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: var(--type-label-sm-weight);
    letter-spacing: var(--type-label-sm-letter-spacing);
    line-height: 1.3;
    text-transform: uppercase;
  }

  .ai-delivery__eyebrow {
    gap: 12px;
  }

  .ai-delivery__eyebrow span {
    background: var(--color-tertiary);
    height: 1px;
    width: 34px;
  }

  .ai-delivery__audience {
    color: var(--color-secondary);
    text-align: right;
  }

  .ai-delivery__introduction {
    align-items: end;
    display: grid;
    gap: clamp(40px, 8vw, 128px);
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.75fr);
  }

  h2 {
    font-size: clamp(3.75rem, 7.7vw, 6.875rem);
    font-weight: 600;
    letter-spacing: -0.065em;
    line-height: 0.88;
    max-width: 900px;
    overflow-wrap: anywhere;
  }

  .ai-delivery__position {
    display: grid;
    gap: 28px;
    max-width: 480px;
    padding-bottom: 8px;
  }

  .ai-delivery__position > p:first-child {
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    letter-spacing: -0.012em;
    line-height: 1.5;
  }

  .ai-delivery__principle {
    border-left: 2px solid var(--color-tertiary);
    color: var(--color-secondary);
    font-size: 0.875rem;
    line-height: 1.55;
    padding-left: 16px;
  }

  .ai-delivery__field {
    border-top: 1px solid var(--color-primary);
    min-width: 0;
  }

  .ai-delivery__outcomes > h3 {
    padding-block: 18px;
  }

  .ai-delivery__outcomes > ol,
  .ai-delivery__process > ol {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-delivery__outcomes > ol {
    border-block: 1px solid var(--color-line);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .ai-delivery__outcome + .ai-delivery__outcome {
    border-left: 1px solid var(--color-line);
  }

  .ai-delivery__outcome a {
    display: flex;
    flex-direction: column;
    min-height: 360px;
    padding: clamp(24px, 3.4vw, 48px);
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .ai-delivery__outcome a:hover,
  .ai-delivery__outcome a:focus-visible {
    background: var(--color-surface-raised);
  }

  .ai-delivery__outcome-label {
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: var(--type-label-sm-weight);
    gap: 12px;
    letter-spacing: var(--type-label-sm-letter-spacing);
    line-height: 1.3;
    text-transform: uppercase;
  }

  .ai-delivery__outcome-label span {
    color: var(--color-tertiary);
  }

  .ai-delivery__outcome h4,
  .ai-delivery__process h4 {
    margin: 0;
  }

  .ai-delivery__outcome h4 {
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1;
    margin-top: clamp(36px, 5vw, 72px);
    max-width: 330px;
  }

  .ai-delivery__outcome-description {
    color: var(--color-secondary);
    font-size: 0.9375rem;
    line-height: 1.55;
    margin-top: 20px;
    max-width: 360px;
  }

  .ai-delivery__outcome-action {
    border-top: 1px solid var(--color-line);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    justify-content: space-between;
    letter-spacing: 0.045em;
    margin-top: auto;
    min-height: 48px;
    padding-top: 12px;
    text-transform: uppercase;
  }

  .ai-delivery__outcome-action span:last-child {
    color: var(--color-secondary);
    font-size: 0.875rem;
    transition:
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .ai-delivery__outcome a:hover .ai-delivery__outcome-action span:last-child,
  .ai-delivery__outcome a:focus-visible .ai-delivery__outcome-action span:last-child {
    color: var(--color-tertiary);
    transform: translate(3px, 3px);
  }

  .ai-delivery__route {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    height: 56px;
    position: relative;
  }

  .ai-delivery__route::after {
    background: var(--color-line);
    bottom: 0;
    content: '';
    height: 1px;
    left: 16.666%;
    position: absolute;
    right: 16.666%;
  }

  .ai-delivery__route span {
    background: var(--color-line);
    height: 100%;
    justify-self: center;
    position: relative;
    transition: background-color var(--transition-fast);
    width: 1px;
    z-index: 1;
  }

  .ai-delivery__route span::after {
    background: var(--color-neutral);
    border: 1px solid var(--color-line);
    border-radius: 50%;
    bottom: -4px;
    content: '';
    height: 7px;
    left: 50%;
    position: absolute;
    transform: translateX(-50%);
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast);
    width: 7px;
  }

  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(1):hover)
    .ai-delivery__route span:nth-child(1),
  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(1):focus-within)
    .ai-delivery__route span:nth-child(1),
  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(2):hover)
    .ai-delivery__route span:nth-child(2),
  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(2):focus-within)
    .ai-delivery__route span:nth-child(2),
  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(3):hover)
    .ai-delivery__route span:nth-child(3),
  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(3):focus-within)
    .ai-delivery__route span:nth-child(3) {
    background: var(--color-tertiary);
  }

  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(1):hover)
    .ai-delivery__route span:nth-child(1)::after,
  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(1):focus-within)
    .ai-delivery__route span:nth-child(1)::after,
  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(2):hover)
    .ai-delivery__route span:nth-child(2)::after,
  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(2):focus-within)
    .ai-delivery__route span:nth-child(2)::after,
  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(3):hover)
    .ai-delivery__route span:nth-child(3)::after,
  .ai-delivery__field:has(.ai-delivery__outcome:nth-child(3):focus-within)
    .ai-delivery__route span:nth-child(3)::after {
    background: var(--color-tertiary);
    border-color: var(--color-tertiary);
  }

  .ai-delivery__process {
    border-top: 1px solid var(--color-primary);
    scroll-margin-top: 24px;
  }

  .ai-delivery__process > header {
    align-items: start;
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(180px, 0.55fr) minmax(0, 1.45fr);
    padding-block: clamp(32px, 5vw, 64px);
  }

  .ai-delivery__process header > p {
    color: var(--color-secondary);
  }

  .ai-delivery__process h3 {
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    font-weight: 600;
    letter-spacing: -0.06em;
    line-height: 0.92;
    max-width: 760px;
  }

  .ai-delivery__process > ol {
    border-top: 1px solid var(--color-line);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .ai-delivery__process li {
    min-height: 300px;
    padding: clamp(24px, 3vw, 40px) clamp(18px, 2.5vw, 32px);
  }

  .ai-delivery__process li + li {
    border-left: 1px solid var(--color-line);
  }

  .ai-delivery__process li > span {
    color: var(--color-tertiary);
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: 500;
    letter-spacing: var(--type-label-sm-letter-spacing);
  }

  .ai-delivery__process h4 {
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin-top: clamp(40px, 5vw, 72px);
  }

  .ai-delivery__process li p {
    color: var(--color-secondary);
    font-size: 0.875rem;
    line-height: 1.55;
    margin-top: 18px;
  }

  .ai-delivery__footer {
    border-top: 1px solid var(--color-primary);
    gap: 48px;
    justify-content: space-between;
    padding-top: 20px;
  }

  .ai-delivery__footer > p {
    color: var(--color-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
    max-width: 570px;
  }

  .ai-delivery__footer a {
    border-bottom: 1px solid currentColor;
    flex: 0 0 min(300px, 26vw);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    justify-content: space-between;
    letter-spacing: 0.025em;
    min-height: 48px;
    text-decoration: none;
    transition: padding-inline var(--transition-fast);
  }

  .ai-delivery__footer a:hover {
    padding-inline: 8px;
  }

  @media (max-width: 900px) {
    .ai-delivery__introduction {
      align-items: start;
      grid-template-columns: 1fr;
    }

    .ai-delivery__position {
      max-width: 620px;
    }

    .ai-delivery__process > ol {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ai-delivery__process li:nth-child(3) {
      border-left: 0;
      border-top: 1px solid var(--color-line);
    }

    .ai-delivery__process li:nth-child(4) {
      border-top: 1px solid var(--color-line);
    }
  }

  @media (max-width: 700px) {
    .ai-delivery__inner,
    .ai-delivery__header {
      gap: 64px;
    }

    .ai-delivery__rail {
      align-items: flex-start;
      gap: 24px;
    }

    .ai-delivery__eyebrow {
      gap: 9px;
    }

    .ai-delivery__eyebrow span {
      width: 24px;
    }

    .ai-delivery__audience {
      max-width: 130px;
    }

    h2 {
      font-size: clamp(3.25rem, 15vw, 4.25rem);
    }

    .ai-delivery__outcomes > ol,
    .ai-delivery__process > ol,
    .ai-delivery__process > header {
      grid-template-columns: 1fr;
    }

    .ai-delivery__outcome + .ai-delivery__outcome,
    .ai-delivery__process li + li {
      border-left: 0;
      border-top: 1px solid var(--color-line);
    }

    .ai-delivery__outcome a {
      min-height: 330px;
    }

    .ai-delivery__route {
      display: none;
    }

    .ai-delivery__process {
      margin-top: 48px;
    }

    .ai-delivery__process > header {
      gap: 32px;
    }

    .ai-delivery__process li {
      min-height: 260px;
    }

    .ai-delivery__footer {
      align-items: stretch;
      flex-direction: column;
      gap: 32px;
    }

    .ai-delivery__footer a {
      flex-basis: auto;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-delivery__outcome a,
    .ai-delivery__outcome-action span:last-child,
    .ai-delivery__route span,
    .ai-delivery__route span::after,
    .ai-delivery__footer a {
      transition: none;
    }
  }
</style>
