---
import { contactCtaCopy } from '../copy';

const contourStrands = Array.from({ length: 52 }, (_, index) => {
  const y = 42 + index * 10.6;
  const bend = Math.sin(index * 0.46) * 26;
  const counterBend = Math.cos(index * 0.31) * 18;

  return {
    d: `M 0 ${y} C 132 ${y + bend}, 238 ${y - bend - counterBend}, 354 ${y + bend * 0.4} S 566 ${y - bend * 0.72}, 760 ${y + counterBend}`,
    opacity: 0.76 + (index % 5) * 0.045,
    width: index % 7 === 0 ? 6.4 : 4.6,
  };
});
---

<section class="contact-cta" aria-labelledby="contact-cta-title" data-motion-section="contact">
  <div class="contact-cta__takeover" data-motion="contact-takeover" aria-hidden="true"></div>

  <div class="contact-cta__inner">
    <p class="contact-cta__eyebrow" data-motion="contact-copy">
      <span aria-hidden="true"></span>
      {contactCtaCopy.eyebrow}
    </p>

    <div class="contact-cta__body">
      <div class="contact-cta__upper-stage" data-contact-upper-stage>
        <h2 id="contact-cta-title" data-motion="contact-copy">{contactCtaCopy.title}</h2>

        <div class="contact-cta__sculpture" data-contact-sculpture aria-hidden="true">
          <svg viewBox="0 0 720 620" preserveAspectRatio="xMidYMid meet" focusable="false">
            <defs>
              <clipPath id="contact-sculpture-silhouette">
                <path
                  d="M 130 28 C 260 -2 462 18 604 88 C 698 134 746 220 748 322 C 750 442 696 548 588 594 C 454 650 258 608 132 532 C 56 486 28 408 38 306 C 48 190 62 76 130 28 Z"
                ></path>
              </clipPath>
              <mask id="contact-sculpture-void">
                <rect width="720" height="620" fill="white"></rect>
                <path
                  d="M -40 224 C 82 152 238 166 358 270 C 288 286 250 326 250 374 C 250 428 286 470 346 506 C 216 522 68 472 -40 392 Z"
                  fill="black"
                ></path>
              </mask>
            </defs>

            <g
              clip-path="url(#contact-sculpture-silhouette)"
              mask="url(#contact-sculpture-void)"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
            >
              <path
                class="contact-cta__sculpture-shadow"
                d="M 102 46 C 292 6 562 58 664 170 C 752 268 728 458 612 548 C 490 642 232 590 106 488"
              ></path>
              {
                contourStrands.map((strand) => (
                  <path
                    d={strand.d}
                    stroke-opacity={strand.opacity}
                    stroke-width={strand.width}
                  ></path>
                ))
              }
              <path
                class="contact-cta__sculpture-fold"
                d="M 430 52 C 366 146 398 226 498 286 C 574 332 592 426 526 574"
              ></path>
              <path
                class="contact-cta__sculpture-fold"
                d="M 548 72 C 486 170 510 250 610 320 C 672 364 672 454 612 548"
              ></path>
            </g>
          </svg>
        </div>
      </div>

      <div class="contact-cta__decision">
        <div class="contact-cta__fit">
          <article data-motion="contact-copy">
            <h3>{contactCtaCopy.goodFit.label}</h3>
            <p>{contactCtaCopy.goodFit.body}</p>
          </article>
          <article data-motion="contact-copy">
            <h3>{contactCtaCopy.nonFit.label}</h3>
            <p>{contactCtaCopy.nonFit.body}</p>
          </article>
        </div>

        <div class="contact-cta__invitation">
          <p data-motion="contact-copy">{contactCtaCopy.body}</p>
          <a href={contactCtaCopy.action.href}>
            <span>{contactCtaCopy.action.label}</span>
            <span aria-hidden="true">{contactCtaCopy.action.suffix}</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-cta {
    background: var(--color-tertiary);
    color: var(--color-on-tertiary);
    isolation: isolate;
    overflow-x: clip;
    padding: clamp(72px, 9vw, 128px) clamp(20px, 3.34vw, 48px) clamp(40px, 5vw, 72px);
    position: relative;
  }

  .contact-cta__takeover {
    background: var(--color-tertiary);
    height: clamp(96px, 14svh, 180px);
    inset: 0 0 auto;
    pointer-events: none;
    position: absolute;
    transform: translateY(-100%) scaleY(0);
    transform-origin: bottom center;
    will-change: transform;
    z-index: 0;
  }

  .contact-cta__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(64px, 10vw, 150px);
    margin-inline: auto;
    max-width: 1344px;
    min-height: min(720px, 80svh);
  }

  .contact-cta__eyebrow {
    align-items: center;
    display: flex;
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: var(--type-label-sm-weight);
    gap: 12px;
    letter-spacing: var(--type-label-sm-letter-spacing);
    line-height: var(--type-label-sm-line-height);
    text-transform: uppercase;
  }

  .contact-cta__eyebrow span {
    background: currentColor;
    height: 1px;
    width: 34px;
  }

  .contact-cta__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: space-between;
    gap: clamp(64px, 10vw, 144px);
  }

  .contact-cta__upper-stage {
    display: block;
  }

  h2 {
    font-size: clamp(3.75rem, 8.4vw, 7.5rem);
    font-weight: 600;
    letter-spacing: -0.068em;
    line-height: 0.88;
    max-width: 1160px;
  }

  .contact-cta__sculpture {
    color: var(--color-primary);
    display: none;
    pointer-events: none;
  }

  .contact-cta__sculpture svg {
    height: 100%;
    overflow: visible;
    width: 100%;
  }

  .contact-cta__sculpture-shadow {
    opacity: 0.12;
    stroke-width: 72px;
  }

  .contact-cta__sculpture-fold {
    opacity: 0.92;
    stroke-width: 9px;
  }

  .contact-cta__decision {
    display: grid;
    gap: clamp(40px, 6vw, 80px);
  }

  .contact-cta__fit {
    border-top: 1px solid color-mix(in srgb, var(--color-on-tertiary) 35%, transparent);
    display: grid;
    gap: clamp(28px, 4vw, 56px);
    grid-template-columns: repeat(2, minmax(0, 1fr));
    padding-top: 20px;
  }

  .contact-cta__fit article {
    display: grid;
    gap: 12px;
    max-width: 520px;
  }

  .contact-cta__fit h3 {
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: 600;
    letter-spacing: var(--type-label-sm-letter-spacing);
    line-height: 1.3;
    text-transform: uppercase;
  }

  .contact-cta__fit p,
  .contact-cta__invitation p {
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    letter-spacing: -0.012em;
    line-height: 1.5;
  }

  .contact-cta__invitation {
    align-items: end;
    border-top: 1px solid color-mix(in srgb, var(--color-on-tertiary) 35%, transparent);
    display: flex;
    gap: 48px;
    justify-content: space-between;
    padding-top: 20px;
  }

  .contact-cta__invitation p {
    max-width: 520px;
  }

  .contact-cta__invitation a {
    align-items: center;
    border-bottom: 1px solid currentColor;
    display: inline-flex;
    flex: 0 0 min(300px, 26vw);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    justify-content: space-between;
    letter-spacing: 0.025em;
    min-height: 48px;
    text-decoration: none;
    transition: padding-inline var(--transition-fast);
  }

  .contact-cta__invitation a:hover {
    padding-inline: 8px;
  }

  .contact-cta__invitation a:focus-visible {
    box-shadow: none;
    outline-color: var(--color-primary);
  }

  .contact-cta__invitation a span:last-child {
    font-size: 1rem;
  }

  @media (min-width: 1024px) and (hover: hover) and (pointer: fine) {
    .contact-cta__upper-stage {
      align-items: center;
      display: grid;
      grid-template-columns: minmax(0, 11fr) minmax(0, 9fr);
      min-height: clamp(460px, 43vw, 610px);
    }

    .contact-cta__upper-stage h2 {
      max-width: none;
      position: relative;
      z-index: 1;
    }

    .contact-cta__sculpture {
      align-self: stretch;
      display: grid;
      margin-block: clamp(-36px, -2.5vw, -20px);
      margin-right: clamp(-124px, -8vw, -80px);
      place-items: center;
      width: calc(100% + max(96px, (100vw - 1344px) / 2 + 48px));
    }
  }

  @media (max-width: 700px) {
    .contact-cta__takeover {
      height: clamp(64px, 10svh, 96px);
    }

    .contact-cta__inner {
      gap: 64px;
      min-height: 680px;
    }

    .contact-cta__eyebrow {
      gap: 9px;
    }

    .contact-cta__eyebrow span {
      width: 24px;
    }

    h2 {
      font-size: clamp(3.25rem, 15vw, 4.25rem);
    }

    .contact-cta__fit {
      grid-template-columns: minmax(0, 1fr);
    }

    .contact-cta__invitation {
      align-items: stretch;
      flex-direction: column;
      gap: 32px;
    }

    .contact-cta__invitation a {
      flex-basis: auto;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-cta__invitation a {
      transition: none;
    }
  }
</style>
