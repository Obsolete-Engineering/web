---
import logoUrl from '../assets/img/logo.png';
import { headerCopy } from '../copy';

interface Props {
  variant?: 'overlay' | 'paper';
}

const { variant = 'paper' } = Astro.props;
---

<header
  class:list={['site-header', { 'site-header--overlay': variant === 'overlay' }]}
  aria-label={headerCopy.ariaLabel}
  data-header-variant={variant}
>
  <div class="site-header__inner">
    <div class="site-header__identity">
      <a class="site-header__wordmark" href="/" aria-label={headerCopy.wordmarkAriaLabel}>
        <img class="site-header__wordmark-logo" src={logoUrl.src} alt="" aria-hidden="true" loading="eager" />
        <span>{headerCopy.wordmark}</span>
      </a>
      <span class="site-header__rule" aria-hidden="true"></span>
      <p class="site-header__descriptor">{headerCopy.descriptor}</p>
    </div>

    <nav class="site-header__nav" aria-label={headerCopy.navAriaLabel}>
      {headerCopy.navItems.map((item) => (
        <a class:list={{ "site-header__contact": "accent" in item && item.accent }} href={item.href}>
          {item.label}
          {"accent" in item && item.accent && (
            <span class="site-header__contact-dot" aria-hidden="true"></span>
          )}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-neutral);
    border-bottom: 1px solid var(--color-line);
    color: var(--color-primary);
  }

  .site-header--overlay {
    background: transparent;
    border-bottom-color: rgb(244 241 234 / 0.16);
    color: #f4f1ea;
    left: 0;
    position: absolute;
    top: 0;
    width: 100%;
    z-index: 20;
  }

  .site-header__inner {
    align-items: center;
    display: flex;
    height: 88px;
    padding-inline: clamp(24px, 3.34vw, 48px);
    width: 100%;
  }

  .site-header__identity,
  .site-header__wordmark,
  .site-header__nav,
  .site-header__nav a {
    align-items: center;
    display: flex;
  }

  .site-header__identity {
    gap: 18px;
    min-width: 0;
  }

  .site-header__wordmark {
    color: var(--color-primary);
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    gap: 10px;
    letter-spacing: 0.2em;
    line-height: 1.25;
    text-decoration: none;
  }

  .site-header__wordmark-logo {
    height: 22px;
    object-fit: contain;
    width: 30px;
  }

  .site-header__rule {
    background: var(--color-line);
    flex: 0 0 42px;
    height: 1px;
  }

  .site-header__descriptor {
    color: var(--color-secondary);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.045em;
    line-height: 1.27;
    white-space: nowrap;
  }

  .site-header__nav {
    gap: 36px;
    margin-left: auto;
  }

  .site-header__nav a {
    color: var(--color-primary);
    font-size: 0.8125rem;
    font-weight: 600;
    gap: 8px;
    line-height: 1.25;
    min-height: 44px;
    text-decoration: none;
    text-underline-offset: 5px;
  }

  .site-header__nav a:hover {
    text-decoration: underline;
  }

  .site-header__contact-dot {
    background: var(--color-tertiary);
    border-radius: 50%;
    height: 7px;
    width: 7px;
  }

  .site-header--overlay .site-header__wordmark,
  .site-header--overlay .site-header__nav a {
    color: #f4f1ea;
  }

  .site-header--overlay .site-header__wordmark-logo {
    filter: invert(1) brightness(1.25);
  }

  .site-header--overlay .site-header__rule {
    background: rgb(244 241 234 / 0.3);
  }

  .site-header--overlay .site-header__descriptor {
    color: #bfb4ad;
  }

  @media (max-width: 900px) {
    .site-header__rule,
    .site-header__descriptor {
      display: none;
    }
  }

  @media (max-width: 700px) {
    .site-header__inner {
      height: 64px;
      padding-inline: 20px;
    }

    .site-header__wordmark {
      font-size: 0.8125rem;
      gap: 10px;
      letter-spacing: 0.2em;
    }

    .site-header__wordmark-logo {
      height: 19px;
      width: 26px;
    }

    .site-header__rule,
    .site-header__descriptor,
    .site-header__nav a:not(.site-header__contact) {
      display: none;
    }

    .site-header__nav {
      gap: 0;
    }

    .site-header__nav a {
      font-size: 0.75rem;
      gap: 7px;
    }

    .site-header__contact-dot {
      height: 6px;
      width: 6px;
    }
  }
</style>
