---
import logoUrl from '../assets/img/logo.png';
import { headerCopy } from '../copy';
---

<header class="site-header" aria-label={headerCopy.ariaLabel}>
  <div class="site-header__inner">
    <div class="site-header__identity" aria-label={headerCopy.identityAriaLabel}>
      <a class="site-header__wordmark" href="/" aria-label={headerCopy.wordmarkAriaLabel}>
        <img class="site-header__wordmark-logo" src={logoUrl.src} alt="" aria-hidden="true" loading="eager" />
        <span>{headerCopy.wordmark}</span>
      </a>
      <span class="site-header__rule" aria-hidden="true"></span>
      <p class="site-header__status" aria-label={headerCopy.statusAriaLabel}>
        <span class="site-header__signal" aria-hidden="true"></span>
        <span class="site-header__status-copy">
          {headerCopy.statusLines.map((line) => <span>{line}</span>)}
        </span>
      </p>
    </div>

    <nav class="site-header__nav" aria-label={headerCopy.navAriaLabel}>
      {headerCopy.navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-surface-raised);
    border-block: 1px solid var(--color-line);
    color: var(--color-primary);
  }

  .site-header__inner {
    align-items: center;
    display: flex;
    gap: var(--space-lg);
    min-height: calc(var(--space-xl) * 2);
    padding-inline: clamp(var(--space-lg), 4vw, calc(var(--space-xl) + var(--space-xs)));
    width: 100%;
  }

  .site-header__identity {
    align-items: center;
    display: flex;
    flex: 0 1 auto;
    gap: var(--space-lg);
    min-width: 0;
  }

  .site-header__wordmark {
    align-items: center;
    color: var(--color-primary);
    display: inline-flex;
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: clamp(1rem, 1.7vw, 1.375rem);
    font-weight: 700;
    gap: var(--space-sm);
    letter-spacing: 0.2em;
    line-height: 1;
    text-decoration: none;
  }

  .site-header__wordmark-logo {
    display: block;
    flex: 0 0 auto;
    height: 1em;
    max-height: 1em;
    object-fit: contain;
    width: auto;
  }

  .site-header__rule {
    background: var(--color-muted);
    flex: 0 0 1px;
    height: 34px;
  }

  .site-header__status {
    align-items: center;
    color: var(--color-secondary);
    display: flex;
    flex: 0 1 auto;
    gap: calc(var(--space-sm) + var(--space-xs));
    margin: 0;
    min-width: 0;
  }

  .site-header__signal {
    background: var(--color-tertiary);
    border-radius: var(--radius-full);
    flex: 0 0 7px;
    height: 7px;
    width: 7px;
  }

  .site-header__status-copy {
    display: flex;
    flex-direction: column;
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: 600;
    gap: var(--space-xs);
    letter-spacing: var(--type-label-md-letter-spacing);
    line-height: 1;
    min-width: 0;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .site-header__nav {
    align-items: center;
    display: flex;
    gap: clamp(var(--space-lg), 3.4vw, var(--space-xl));
    margin-left: auto;
  }

  .site-header__nav a {
    border-radius: var(--radius-sm);
    color: var(--color-primary);
    font-size: var(--type-body-sm-size);
    font-weight: 600;
    letter-spacing: var(--type-body-md-letter-spacing);
    line-height: 1;
    padding-block: var(--space-sm);
    text-decoration: none;
    transition:
      color var(--transition-fast),
      text-decoration-color var(--transition-fast);
  }

  .site-header__nav a:hover {
    color: var(--color-secondary);
    text-decoration: underline;
    text-decoration-color: var(--color-tertiary);
    text-decoration-thickness: 2px;
    text-underline-offset: var(--space-sm);
  }

  @media (max-width: 820px) {
    .site-header__inner {
      align-items: stretch;
      flex-direction: column;
      gap: var(--space-md);
      min-height: 0;
      padding-block: var(--space-md);
    }

    .site-header__identity {
      justify-content: space-between;
      width: 100%;
    }

    .site-header__nav {
      border-top: 1px solid var(--color-line);
      gap: var(--space-lg);
      margin-left: 0;
      overflow-x: auto;
      padding-top: var(--space-md);
      scrollbar-width: none;
    }

    .site-header__nav::-webkit-scrollbar {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .site-header__identity {
      align-items: flex-start;
      flex-wrap: wrap;
      gap: var(--space-md);
    }

    .site-header__rule {
      display: none;
    }

    .site-header__status {
      flex-basis: 100%;
    }
  }
</style>
