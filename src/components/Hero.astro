---
import { heroCopy } from '../copy';
---

<section
  class="hero"
  aria-labelledby="hero-title"
  data-fluid-hero
  data-fluid-state="poster"
  data-motion-section="hero"
>
  <div class="hero__backdrop" aria-hidden="true">
    <img
      class="hero__poster"
      src="/fluid-hero-poster.webp"
      alt=""
      width="1920"
      height="1200"
      loading="eager"
      fetchpriority="high"
      data-fluid-poster
    />
    <canvas class="hero__canvas" data-fluid-canvas></canvas>
    <div class="hero__grain"></div>
  </div>

  <div class="hero__content">
    <div class="hero__eyebrow" data-motion="hero-eyebrow">
      <span aria-hidden="true"></span>
      <p>{heroCopy.eyebrow}</p>
      <span aria-hidden="true"></span>
    </div>

    <div class="hero__title-wrap" data-fluid-title-source>
      <h1 id="hero-title" aria-label={heroCopy.title.accessible}>
        <span class="hero__title-visual" aria-hidden="true">
          <span class="hero__title-line" data-title-line="first" data-motion="hero-title-line">
            {heroCopy.title.firstLine}
          </span>
          <span
            class="hero__title-line hero__title-rest"
            data-title-line="rest"
            data-motion="hero-title-line"
          >
            <span class="hero__title-middle" data-title-part="middle">
              {heroCopy.title.middleLine}
            </span>
            <span class="hero__title-space"> </span>
            <span class="hero__title-last" data-title-part="last">
              {heroCopy.title.lastLine}<span class="hero__title-period">
                {heroCopy.title.punctuation}
              </span>
            </span>
          </span>
        </span>
      </h1>

      <div class="hero__title-effect" aria-hidden="true" data-fluid-title-effect>
        <span class="hero__title-line">{heroCopy.title.firstLine}</span>
        <span class="hero__title-line hero__title-rest">
          <span class="hero__title-middle">{heroCopy.title.middleLine}</span>
          <span class="hero__title-space"> </span>
          <span class="hero__title-last">
            {heroCopy.title.lastLine}<span class="hero__title-period">
              {heroCopy.title.punctuation}
            </span>
          </span>
        </span>
      </div>
    </div>

    <div class="hero__clarification" data-motion="hero-clarification">
      <p class="hero__lead">{heroCopy.lead}</p>

      <div class="hero__actions" aria-label={heroCopy.actionsAriaLabel}>
        <a class="hero__action hero__action--primary" href={heroCopy.actions.primary.href}>
          <span>{heroCopy.actions.primary.label}</span>
          <span aria-hidden="true">{heroCopy.actions.primary.suffix}</span>
        </a>
        <a class="hero__action hero__action--secondary" href={heroCopy.actions.secondary.href}>
          <span>{heroCopy.actions.secondary.label}</span>
          <span aria-hidden="true">{heroCopy.actions.secondary.suffix}</span>
        </a>
      </div>
    </div>
  </div>

  <span class="hero__cursor" aria-hidden="true" data-fluid-cursor></span>
</section>

<script>
  import { mountFluidHero } from '../scripts/fluid-hero';

  const root = document.querySelector<HTMLElement>('[data-fluid-hero]');
  const dispose = root ? mountFluidHero(root) : () => {};

  window.addEventListener('pagehide', (event) => {
    if (!event.persisted) dispose();
  });
</script>

<style>
  .hero {
    --fluid-pointer-x: 50%;
    --fluid-pointer-y: 50%;
    --fluid-title-x: 50%;
    --fluid-title-y: 50%;
    background: #070707;
    color: #f4f1ea;
    height: 100svh;
    isolation: isolate;
    overflow: clip;
    position: relative;
  }

  .hero__backdrop,
  .hero__poster,
  .hero__canvas,
  .hero__grain {
    height: 100%;
    inset: 0;
    position: absolute;
    width: 100%;
  }

  .hero__backdrop {
    background: #070707;
    pointer-events: none;
    z-index: 0;
  }

  .hero__poster,
  .hero__canvas {
    display: block;
    object-fit: cover;
  }

  .hero__poster {
    opacity: 1;
    transition: opacity 620ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero__canvas {
    opacity: 0;
    transition: opacity 620ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero[data-fluid-state='live'] .hero__poster {
    opacity: 0;
  }

  .hero[data-fluid-state='live'] .hero__canvas {
    opacity: 1;
  }

  .hero__grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 160 160' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.5'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
    opacity: 0.08;
  }

  .hero__content {
    align-items: center;
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: center;
    margin-inline: auto;
    max-width: 1440px;
    padding: clamp(92px, 11vh, 124px) clamp(20px, 5vw, 72px) clamp(38px, 6vh, 72px);
    position: relative;
    text-align: center;
    z-index: 2;
  }

  .hero__eyebrow {
    align-items: center;
    color: #c6b8ae;
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    gap: 12px;
    letter-spacing: 0.09em;
    line-height: 1.27;
    text-transform: uppercase;
  }

  .hero__eyebrow > span {
    background: #ff5b2b;
    height: 1px;
    width: 28px;
  }

  .hero__title-wrap {
    margin-top: clamp(22px, 3.8vh, 40px);
    max-width: 1320px;
    position: relative;
    width: 100%;
  }

  h1,
  .hero__title-effect {
    font-size: clamp(3.25rem, 7.15vw, 6.5rem);
    font-weight: 600;
    letter-spacing: -0.066em;
    line-height: 0.88;
    margin: 0;
  }

  .hero__title-line {
    display: block;
    white-space: nowrap;
  }

  .hero__title-period {
    color: #ff5b2b;
  }

  .hero__title-effect {
    color: #ff7041;
    filter: blur(0.35px) saturate(1.3);
    inset: 0;
    mask-image: radial-gradient(
      circle 92px at var(--fluid-title-x) var(--fluid-title-y),
      #000 0,
      rgb(0 0 0 / 0.85) 34%,
      transparent 72%
    );
    opacity: 0;
    pointer-events: none;
    position: absolute;
    text-shadow: -3px 0 0 rgb(255 177 74 / 0.38), 3px 0 0 rgb(119 20 20 / 0.7);
    transform: translate3d(0, 1px, 0) scaleX(1.003);
    transition: opacity 180ms ease;
  }

  .hero[data-fluid-title-active] .hero__title-effect {
    opacity: 0.72;
  }

  .hero__clarification {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: clamp(22px, 3.4vh, 32px);
    margin-top: clamp(30px, 5.2vh, 54px);
    max-width: 680px;
  }

  .hero__lead {
    color: #d8cdc6;
    font-size: clamp(1rem, 1.45vw, 1.22rem);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.5;
    text-wrap: balance;
  }

  .hero__actions {
    align-items: center;
    display: flex;
    gap: 24px;
    justify-content: center;
  }

  .hero__action {
    align-items: center;
    color: #f4f1ea;
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    gap: 10px;
    letter-spacing: 0.025em;
    line-height: 1.33;
    min-height: 44px;
    text-decoration: none;
    transition: background-color var(--transition-fast), color var(--transition-fast),
      transform var(--transition-fast);
  }

  .hero__action:hover {
    transform: translateY(-1px);
  }

  .hero__action:active {
    transform: translateY(0);
  }

  .hero__action--primary {
    background: #ff5b2b;
    color: #0b0908;
    gap: 20px;
    justify-content: center;
    padding-inline: 18px;
  }

  .hero__action--primary:hover {
    background: #ff7041;
  }

  .hero__action--secondary {
    border-bottom: 1px solid rgb(244 241 234 / 0.72);
    padding-block: 12px;
  }

  .hero__action--secondary:hover {
    color: #ff8a57;
  }

  .hero__cursor {
    background: #ff632f;
    border: 1px solid rgb(255 178 107 / 0.7);
    border-radius: 50%;
    box-shadow: 0 0 18px rgb(255 75 31 / 0.62);
    display: none;
    height: 9px;
    left: 0;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    top: 0;
    transform: translate3d(calc(var(--fluid-pointer-x) - 50%), calc(var(--fluid-pointer-y) - 50%), 0);
    transition: opacity 140ms ease;
    width: 9px;
    z-index: 4;
  }

  @media (hover: hover) and (pointer: fine) {
    .hero__cursor {
      display: block;
    }

    .hero[data-fluid-pointer-active] .hero__cursor {
      opacity: 1;
    }

    .hero[data-fluid-pointer-control] .hero__cursor {
      opacity: 0;
    }
  }

  @media (max-width: 700px) {
    .hero__content {
      padding: 80px 20px 34px;
    }

    .hero__eyebrow {
      font-size: 0.5625rem;
      gap: 9px;
      letter-spacing: 0.072em;
    }

    .hero__eyebrow > span {
      width: 20px;
    }

    .hero__title-wrap {
      margin-top: clamp(28px, 4.6vh, 40px);
    }

    h1,
    .hero__title-effect {
      font-size: clamp(2.7rem, 14.35vw, 3.5rem);
      letter-spacing: -0.064em;
      line-height: 0.91;
    }

    .hero__title-middle,
    .hero__title-last {
      display: block;
    }

    .hero__title-space {
      display: none;
    }

    .hero__clarification {
      gap: 20px;
      margin-top: clamp(30px, 5.6vh, 46px);
      max-width: 355px;
    }

    .hero__lead {
      font-size: 0.9375rem;
      line-height: 1.48;
    }

    .hero__actions {
      gap: 18px;
    }

    .hero__action {
      font-size: 0.6875rem;
    }

    .hero__action--primary {
      gap: 14px;
      padding-inline: 15px;
    }

    .hero__title-effect {
      mask-image: radial-gradient(
        circle 68px at var(--fluid-title-x) var(--fluid-title-y),
        #000 0,
        rgb(0 0 0 / 0.8) 34%,
        transparent 74%
      );
    }
  }

  @media (max-width: 340px) {
    .hero__content {
      padding-inline: 16px;
    }

    h1,
    .hero__title-effect {
      font-size: 2.72rem;
    }

    .hero__clarification {
      margin-top: 28px;
    }

    .hero__actions {
      gap: 12px;
    }
  }

  @media (max-height: 720px) and (min-width: 701px) {
    .hero__content {
      padding-block: 84px 30px;
    }

    .hero__title-wrap {
      margin-top: 18px;
    }

    .hero__clarification {
      gap: 18px;
      margin-top: 24px;
    }
  }

  @media (max-height: 520px) and (min-width: 701px) {
    .hero__content {
      justify-content: flex-start;
      padding: 100px 24px 18px;
    }

    .hero__title-wrap {
      margin-top: 10px;
    }

    h1,
    .hero__title-effect {
      font-size: 2.8rem;
    }

    .hero__clarification {
      gap: 10px;
      margin-top: 12px;
    }

    .hero__lead {
      font-size: 0.8125rem;
      line-height: 1.3;
    }
  }

  @media (max-height: 560px) and (max-width: 700px) {
    .hero__content {
      justify-content: flex-start;
      padding: 76px 16px 16px;
    }

    .hero__title-wrap {
      margin-top: 12px;
    }

    h1,
    .hero__title-effect {
      font-size: 2.5rem;
    }

    .hero__clarification {
      gap: 10px;
      margin-top: 14px;
    }

    .hero__lead {
      font-size: 0.8rem;
      line-height: 1.35;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__poster,
    .hero__canvas,
    .hero__title-effect,
    .hero__action,
    .hero__cursor {
      transition: none;
    }

    .hero__cursor,
    .hero__title-effect {
      display: none;
    }
  }
</style>
