---
import { heroCopy } from '../copy';
import { HERO_CEREMONY_SESSION_KEY } from '../scripts/hero-ceremony';
---

<section
  class="hero"
  aria-labelledby="hero-title"
  data-fluid-hero
  data-fluid-state="poster"
  data-ceremony-pointer-dye="gated"
  data-ceremony-session-key={HERO_CEREMONY_SESSION_KEY}
  data-ceremony-state="pending"
  data-motion-section="hero"
>
  <div class="hero__backdrop" aria-hidden="true">
    <img
      class="hero__poster"
      src="/fluid-hero-poster.webp"
      alt=""
      width="1920"
      height="1200"
      loading="eager"
      fetchpriority="high"
      data-fluid-poster
    />
    <canvas class="hero__canvas" data-fluid-canvas></canvas>
  </div>

  <script is:inline>
    (() => {
      const root = document.currentScript?.closest('[data-fluid-hero]');
      const canvas = root?.querySelector('[data-fluid-canvas]');
      if (!(root instanceof HTMLElement) || !(canvas instanceof HTMLCanvasElement)) return;

      // This parser-blocking probe intentionally mirrors the engine's render-target checks.
      // Keeping it here prevents a deferred client bundle from withholding the fallback UI.
      const supportsFluidRendering = () => {
        const attributes = {
          alpha: false,
          antialias: false,
          depth: false,
          powerPreference: 'high-performance',
          premultipliedAlpha: false,
          preserveDrawingBuffer: false,
          stencil: false,
        };
        const context =
          canvas.getContext('webgl2', attributes) ?? canvas.getContext('webgl', attributes);
        if (!context) return false;

        const isWebGl2 =
          typeof WebGL2RenderingContext !== 'undefined' &&
          context instanceof WebGL2RenderingContext;
        const halfFloat = isWebGl2 ? null : context.getExtension('OES_texture_half_float');
        if (isWebGl2 && !context.getExtension('EXT_color_buffer_float')) return false;
        if (
          !isWebGl2 &&
          (!halfFloat || !context.getExtension('EXT_color_buffer_half_float'))
        ) {
          return false;
        }

        const texture = context.createTexture();
        const framebuffer = context.createFramebuffer();
        if (!texture || !framebuffer) return false;
        try {
          context.bindTexture(context.TEXTURE_2D, texture);
          context.texParameteri(context.TEXTURE_2D, context.TEXTURE_MIN_FILTER, context.NEAREST);
          context.texParameteri(context.TEXTURE_2D, context.TEXTURE_MAG_FILTER, context.NEAREST);
          context.texImage2D(
            context.TEXTURE_2D,
            0,
            isWebGl2 ? context.RGBA16F : context.RGBA,
            1,
            1,
            0,
            context.RGBA,
            isWebGl2 ? context.HALF_FLOAT : halfFloat.HALF_FLOAT_OES,
            null,
          );
          context.bindFramebuffer(context.FRAMEBUFFER, framebuffer);
          context.framebufferTexture2D(
            context.FRAMEBUFFER,
            context.COLOR_ATTACHMENT0,
            context.TEXTURE_2D,
            texture,
            0,
          );
          return context.checkFramebufferStatus(context.FRAMEBUFFER) === context.FRAMEBUFFER_COMPLETE;
        } catch {
          return false;
        } finally {
          context.bindFramebuffer(context.FRAMEBUFFER, null);
          context.bindTexture(context.TEXTURE_2D, null);
          context.deleteFramebuffer(framebuffer);
          context.deleteTexture(texture);
        }
      };

      const sessionKey = root.dataset.ceremonySessionKey;
      let sessionAvailable = Boolean(sessionKey);
      let hasCompleted = false;
      if (sessionKey) {
        try {
          const probeKey = `${sessionKey}:probe`;
          window.sessionStorage.setItem(probeKey, '1');
          window.sessionStorage.removeItem(probeKey);
          hasCompleted = window.sessionStorage.getItem(sessionKey) === 'true';
        } catch {
          sessionAvailable = false;
        }
      }

      let skipReason;
      if (hasCompleted) skipReason = 'repeat-session';
      else if (window.location.hash.length > 1) skipReason = 'hash';
      else if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        skipReason = 'reduced-motion';
      } else if (sessionAvailable === false) skipReason = 'storage';
      else if (!supportsFluidRendering()) skipReason = 'unsupported-webgl';

      if (skipReason) {
        root.dataset.ceremonyPreflight = 'skipped';
        root.dataset.ceremonyProgress = '1';
        root.dataset.ceremonySkipReason = skipReason;
        root.dataset.ceremonyState = 'skipped';
        if (skipReason === 'unsupported-webgl') root.dataset.fluidState = 'fallback';
      } else {
        root.dataset.ceremonyPreflight = 'eligible';
      }
    })();
  </script>

  <span class="hero__pointer-dot" aria-hidden="true" data-fluid-pointer-dot></span>

  <div class="hero__content">
    <div
      class="hero__eyebrow"
      data-ceremony-part="eyebrow"
      data-motion="hero-eyebrow"
    >
      <span aria-hidden="true"></span>
      <p>{heroCopy.eyebrow}</p>
      <span aria-hidden="true"></span>
    </div>

    <div class="hero__title-wrap">
      <h1 id="hero-title" aria-label={heroCopy.title.accessible}>
        <span class="hero__title-visual" aria-hidden="true">
          <span
            class="hero__title-line"
            data-title-line="first"
            data-ceremony-part="headline-first"
            data-motion="hero-title-line"
          >
            {heroCopy.title.firstLine}
          </span>
          <span
            class="hero__title-line hero__title-rest"
            data-title-line="rest"
            data-ceremony-part="headline-rest"
            data-motion="hero-title-line"
          >
            <span
              class="hero__title-middle"
              data-title-part="middle"
            >
              {heroCopy.title.middleLine}
            </span>
            <span class="hero__title-space"> </span>
            <span
              class="hero__title-last"
              data-title-part="last"
            >
              {heroCopy.title.lastLine}<span
                class="hero__title-period"
                data-ceremony-part="period"
              >
                {heroCopy.title.punctuation}
              </span>
            </span>
          </span>
        </span>
      </h1>
    </div>

    <div class="hero__clarification" data-motion="hero-clarification">
      <p class="hero__lead" data-ceremony-part="clarification">{heroCopy.lead}</p>

      <div
        class="hero__actions"
        aria-label={heroCopy.actionsAriaLabel}
        data-ceremony-part="actions"
      >
        <a class="hero__action hero__action--primary" href={heroCopy.actions.primary.href}>
          <span>{heroCopy.actions.primary.label}</span>
          <span aria-hidden="true">{heroCopy.actions.primary.suffix}</span>
        </a>
        <a class="hero__action hero__action--secondary" href={heroCopy.actions.secondary.href}>
          <span>{heroCopy.actions.secondary.label}</span>
          <span aria-hidden="true">{heroCopy.actions.secondary.suffix}</span>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { mountFluidHero } from '../scripts/fluid-hero';

  const root = document.querySelector<HTMLElement>('[data-fluid-hero]');
  const dispose = root ? mountFluidHero(root) : () => {};

  window.addEventListener('pagehide', (event) => {
    if (!event.persisted) dispose();
  });
</script>

<style>
  .hero {
    background: var(--color-neutral);
    color: var(--color-primary);
    isolation: isolate;
    min-height: 100svh;
    overflow: clip;
    position: relative;
  }

  .hero__backdrop,
  .hero__poster,
  .hero__canvas {
    height: 100%;
    inset: 0;
    position: absolute;
    width: 100%;
  }

  .hero__backdrop {
    background: var(--color-neutral);
    pointer-events: none;
    z-index: 0;
  }

  .hero__poster,
  .hero__canvas {
    display: block;
    object-fit: cover;
  }

  .hero__poster {
    opacity: 1;
    transition: opacity 360ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero__canvas {
    opacity: 0;
    transition: opacity 360ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (scripting: enabled) and (prefers-reduced-motion: no-preference) {
    .hero[data-ceremony-state='eligible'] .hero__poster,
    .hero[data-ceremony-state='ready'] .hero__poster {
      opacity: 0.22;
    }

    .hero[data-ceremony-variant='mobile'][data-ceremony-state='eligible'] .hero__poster {
      opacity: 0.48;
    }
  }

  @media (scripting: none) {
    .hero[data-ceremony-state='pending'] .hero__poster {
      opacity: 1;
    }
  }

  .hero[data-ceremony-state='ready'] .hero__poster,
  .hero[data-ceremony-state='ready'] .hero__canvas,
  .hero[data-ceremony-state='running'] .hero__poster,
  .hero[data-ceremony-state='running'] .hero__canvas {
    transition: none;
  }

  .hero[data-fluid-state='live'] .hero__poster {
    opacity: 0;
  }

  .hero[data-fluid-state='live'] .hero__canvas {
    opacity: 1;
  }

  .hero__pointer-dot {
    background: color-mix(in srgb, var(--color-primary) 42%, transparent);
    border-radius: 50%;
    height: 6px;
    left: 0;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    top: 0;
    transition: opacity 120ms ease-out;
    visibility: hidden;
    width: 6px;
    will-change: transform;
    z-index: 3;
  }

  .hero[data-fluid-state='live'][data-fluid-pointer-active='true'] .hero__pointer-dot {
    opacity: 1;
    visibility: visible;
  }

  .hero__content {
    align-items: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-inline: auto;
    max-width: 1440px;
    min-height: 100svh;
    padding: clamp(92px, 11vh, 124px) clamp(20px, 5vw, 72px) clamp(38px, 6vh, 72px);
    position: relative;
    text-align: center;
    z-index: 2;
  }

  .hero__eyebrow {
    align-items: center;
    color: var(--color-primary);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    gap: 12px;
    letter-spacing: 0.09em;
    line-height: 1.27;
    text-transform: uppercase;
  }

  .hero__eyebrow > span {
    background: var(--color-line);
    height: 1px;
    width: 28px;
  }

  .hero__title-wrap {
    margin-top: clamp(22px, 3.8vh, 40px);
    max-width: 1320px;
    position: relative;
    width: 100%;
  }

  h1 {
    color: var(--color-primary);
    font-size: clamp(3.25rem, 7.15vw, 6.5rem);
    font-weight: 600;
    letter-spacing: -0.066em;
    line-height: 0.88;
    margin: 0;
  }

  .hero__title-line {
    display: block;
    white-space: nowrap;
  }

  .hero__title-rest {
    white-space: normal;
  }

  .hero__title-middle,
  .hero__title-last {
    display: inline-block;
  }

  .hero__title-period {
    color: var(--color-tertiary);
  }

  .hero__clarification {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: clamp(22px, 3.4vh, 32px);
    margin-top: clamp(30px, 5.2vh, 54px);
    max-width: 680px;
  }

  .hero__lead {
    color: var(--color-primary);
    font-size: clamp(1rem, 1.45vw, 1.22rem);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.5;
    text-wrap: balance;
  }

  .hero__actions {
    align-items: center;
    display: flex;
    gap: 24px;
    justify-content: center;
  }

  .hero__action {
    align-items: center;
    color: var(--color-primary);
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    gap: 10px;
    letter-spacing: 0.025em;
    line-height: 1.33;
    min-height: 44px;
    text-decoration: none;
    transition: background-color var(--transition-fast), color var(--transition-fast),
      transform var(--transition-fast);
  }

  .hero__action:hover {
    transform: translateY(-1px);
  }

  .hero__action:active {
    transform: translateY(0);
  }

  .hero__action--primary {
    background: var(--color-tertiary);
    color: var(--color-on-tertiary);
    gap: 20px;
    justify-content: center;
    padding-inline: 18px;
  }

  .hero__action--primary:hover {
    background: color-mix(in srgb, var(--color-tertiary) 88%, var(--color-primary));
  }

  .hero__action--secondary {
    border-bottom: 1px solid color-mix(in srgb, var(--color-primary) 68%, transparent);
    padding-block: 12px;
  }

  .hero__action--secondary:hover {
    color: var(--color-tertiary);
  }

  @media (max-width: 700px) {
    .hero__content {
      padding: 80px 20px 34px;
    }

    .hero__eyebrow {
      font-size: 0.5625rem;
      gap: 9px;
      letter-spacing: 0.072em;
    }

    .hero__eyebrow > span {
      width: 20px;
    }

    .hero__title-wrap {
      margin-top: clamp(28px, 4.6vh, 40px);
    }

    h1 {
      font-size: clamp(2.7rem, 14.35vw, 3.5rem);
      letter-spacing: -0.064em;
      line-height: 0.91;
    }

    .hero__title-middle,
    .hero__title-last {
      display: block;
    }

    .hero__title-space {
      display: none;
    }

    .hero__clarification {
      gap: 20px;
      margin-top: clamp(30px, 5.6vh, 46px);
      max-width: 355px;
    }

    .hero__lead {
      font-size: 0.9375rem;
      line-height: 1.48;
    }

    .hero__actions {
      gap: 18px;
    }

    .hero__action {
      font-size: 0.6875rem;
    }

    .hero__action--primary {
      gap: 14px;
      padding-inline: 15px;
    }
  }

  @media (max-width: 340px) {
    .hero__content {
      padding-inline: 16px;
    }

    h1 {
      font-size: 2.72rem;
    }

    .hero__clarification {
      margin-top: 28px;
    }

    .hero__actions {
      gap: 12px;
    }
  }

  @media (max-height: 720px) and (min-width: 701px) {
    .hero__content {
      padding-block: 84px 30px;
    }

    .hero__title-wrap {
      margin-top: 18px;
    }

    .hero__clarification {
      gap: 18px;
      margin-top: 24px;
    }
  }

  @media (max-height: 520px) and (min-width: 701px) {
    .hero__content {
      justify-content: flex-start;
      padding: 94px 24px 18px;
    }

    .hero__title-wrap {
      margin-top: 10px;
    }

    h1 {
      font-size: 2.8rem;
    }

    .hero__clarification {
      gap: 10px;
      margin-top: 12px;
    }

    .hero__lead {
      font-size: 0.8125rem;
      line-height: 1.3;
    }
  }

  @media (max-height: 560px) and (max-width: 700px) {
    .hero__content {
      justify-content: flex-start;
      padding: 76px 16px 16px;
    }

    .hero__title-wrap {
      margin-top: 12px;
    }

    h1 {
      font-size: 2.5rem;
    }

    .hero__clarification {
      gap: 10px;
      margin-top: 14px;
    }

    .hero__lead {
      font-size: 0.8rem;
      line-height: 1.35;
    }
  }

  @media (hover: none), (pointer: coarse), (prefers-reduced-motion: reduce) {
    .hero__pointer-dot {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__poster,
    .hero__canvas,
    .hero__pointer-dot,
    .hero__action {
      transition: none;
    }
  }
</style>
