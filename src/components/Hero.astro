---
import logoUrl from "../assets/img/logo.png";
import { heroCopy } from "../copy";
import ObsoleteHeroIsland from "./ObsoleteHeroIsland";
---

<section class="hero" aria-labelledby="hero-title">
    <div class="hero__eyebrow">
        <span aria-hidden="true"></span>
        <p>{heroCopy.eyebrow}</p>
    </div>

    <h1 id="hero-title" aria-label={heroCopy.title.accessible}>
        <span class="hero__title-visual" aria-hidden="true">
            <span class="hero__title-line">{heroCopy.title.firstLine}</span>
            <span class="hero__title-middle">{heroCopy.title.middleLine}<span class="hero__title-space"> </span></span>
            <span class="hero__title-last">{heroCopy.title.lastLine}<span class="hero__title-period">{heroCopy.title.punctuation}</span></span>
        </span>
    </h1>

    <div class="hero__clarification">
        <p class="hero__lead">{heroCopy.lead}</p>

        <div class="hero__actions" aria-label={heroCopy.actionsAriaLabel}>
            <a class="hero__action hero__action--primary" href={heroCopy.actions.primary.href}>
                <span>{heroCopy.actions.primary.label}</span>
                <span aria-hidden="true">{heroCopy.actions.primary.suffix}</span>
            </a>
            <a class="hero__action hero__action--secondary" href={heroCopy.actions.secondary.href}>
                <span>{heroCopy.actions.secondary.label}</span>
                <span aria-hidden="true">{heroCopy.actions.secondary.suffix}</span>
            </a>
        </div>
    </div>

    <div class="hero__visual" role="img" aria-label={heroCopy.visualAriaLabel}>
        <img class="hero__visual-fallback" src={logoUrl.src} alt="" aria-hidden="true" loading="eager" />
        <div class="hero__island" aria-hidden="true">
            <ObsoleteHeroIsland client:only="react" />
        </div>
        <p class="hero__visual-caption" aria-hidden="true">{heroCopy.visualCaption}</p>
    </div>
</section>

<style>
    .hero {
        background: var(--color-neutral);
        color: var(--color-primary);
        min-height: calc(100svh - 88px);
        overflow: clip;
        padding: 52px 48px 40px;
        position: relative;
    }

    .hero__eyebrow {
        align-items: center;
        color: var(--color-secondary);
        display: flex;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        font-weight: 500;
        gap: 12px;
        letter-spacing: 0.064em;
        line-height: 1.27;
        text-transform: uppercase;
    }

    .hero__eyebrow > span {
        background: var(--color-tertiary);
        height: 1px;
        width: 34px;
    }

    h1 {
        font-size: clamp(5.25rem, 8.06vw, 7.25rem);
        font-weight: 600;
        left: 48px;
        letter-spacing: -0.06em;
        line-height: 0.9;
        margin: 0;
        position: absolute;
        top: 126px;
        white-space: nowrap;
    }

    .hero__title-line {
        display: block;
    }

    .hero__title-middle,
    .hero__title-last {
        display: inline;
    }

    .hero__title-period {
        color: var(--color-tertiary);
    }

    .hero__clarification {
        display: flex;
        flex-direction: column;
        gap: 26px;
        left: 48px;
        position: absolute;
        top: 555px;
        width: min(430px, calc(100% - 96px));
    }

    .hero__lead {
        font-family: var(--font-sans);
        font-size: 1.25rem;
        font-weight: 400;
        letter-spacing: -0.015em;
        line-height: 1.42;
    }

    .hero__actions {
        align-items: center;
        display: flex;
        gap: 22px;
    }

    .hero__action {
        align-items: center;
        color: var(--color-primary);
        display: inline-flex;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        gap: 9px;
        letter-spacing: 0.025em;
        line-height: 1.33;
        min-height: 44px;
        text-decoration: none;
        transition: color var(--transition-fast), transform var(--transition-fast);
    }

    .hero__action:hover {
        transform: translateY(-1px);
    }

    .hero__action--primary {
        background: var(--color-tertiary);
        border-radius: var(--radius-sm);
        gap: 22px;
        justify-content: center;
        padding-inline: 18px;
    }

    .hero__action--secondary {
        border-bottom: 1px solid var(--color-primary);
        padding-block: 12px;
    }

    .hero__visual {
        align-items: center;
        aspect-ratio: 64 / 30;
        display: flex;
        justify-content: center;
        max-width: 640px;
        overflow: visible;
        position: absolute;
        right: 34px;
        top: 468px;
        width: min(44.45vw, 640px);
    }

    .hero__visual-fallback {
        height: auto;
        opacity: 0.14;
        width: 46.875%;
    }

    .hero__island {
        inset: 0;
        overflow: hidden;
        position: absolute;
    }

    .hero__visual-caption {
        bottom: 4px;
        color: var(--color-muted);
        font-family: var(--font-mono);
        font-size: 0.625rem;
        font-weight: 500;
        letter-spacing: 0.07em;
        line-height: 1.2;
        position: absolute;
        right: 10px;
        text-transform: uppercase;
    }

    @media (prefers-reduced-motion: reduce) {
        .hero__action {
            transition: none;
        }
    }

    @media (min-width: 701px) and (max-width: 1199px) {
        .hero {
            display: flex;
            flex-direction: column;
            min-height: calc(100svh - 88px);
            padding-inline: clamp(24px, 4.7vw, 48px);
        }

        h1,
        .hero__clarification,
        .hero__visual {
            left: auto;
            position: relative;
            right: auto;
            top: auto;
        }

        h1 {
            font-size: clamp(3.5rem, 7.5vw, 6rem);
            margin-top: 54px;
        }

        .hero__clarification {
            margin-top: clamp(72px, 9vw, 108px);
            width: min(520px, 62vw);
        }

        .hero__visual {
            align-self: flex-end;
            margin-top: -80px;
            width: min(58vw, 640px);
        }
    }

    @media (max-width: 700px) {
        .hero {
            display: flex;
            flex-direction: column;
            min-height: calc(100svh - 64px);
            padding: 28px 20px 22px;
        }

        .hero__eyebrow {
            font-size: 0.5625rem;
            gap: 9px;
            letter-spacing: 0.061em;
            line-height: 1.33;
        }

        .hero__eyebrow > span {
            width: 24px;
        }

        h1,
        .hero__clarification,
        .hero__visual {
            left: auto;
            position: relative;
            right: auto;
            top: auto;
        }

        h1 {
            font-size: clamp(2.75rem, 14.88vw, 3.625rem);
            letter-spacing: -0.0655em;
            line-height: 0.91;
            margin-top: 36px;
            white-space: nowrap;
        }

        .hero__title-middle,
        .hero__title-last {
            display: block;
        }

        .hero__title-space {
            display: none;
        }

        .hero__clarification {
            gap: 20px;
            margin-top: 52px;
            width: min(335px, 100%);
        }

        .hero__lead {
            font-size: 1rem;
            letter-spacing: -0.0094em;
            line-height: 1.42;
        }

        .hero__actions {
            gap: 18px;
        }

        .hero__action {
            font-size: 0.6875rem;
            letter-spacing: 0.018em;
            line-height: 1.27;
        }

        .hero__action--primary {
            gap: 17px;
            padding-inline: 16px;
        }

        .hero__visual {
            align-self: center;
            flex: 0 0 auto;
            margin-top: 68px;
            width: calc(100% + 12px);
        }

        .hero__visual-caption {
            bottom: -24px;
            font-size: 0.5rem;
            letter-spacing: 0.075em;
            right: 0;
        }
    }

    @media (max-width: 340px) {
        h1 {
            font-size: 2.8rem;
        }

        .hero__actions {
            align-items: flex-start;
            flex-direction: column;
            gap: 8px;
        }

        .hero__visual {
            margin-top: 48px;
        }
    }
</style>
