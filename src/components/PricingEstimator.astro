---
import { pricingEstimatorCopy as copy } from '../copy';
import PricingResult from './PricingResult.astro';
---

<section
  class="pricing-estimator"
  id="pricing"
  aria-label={copy.ariaLabel}
  data-announcement-estimate={copy.announcement.estimate}
  data-announcement-vat={copy.announcement.vat}
  data-pricing-estimator
>
  <div class="pricing-estimator__inner">
    <header class="pricing-estimator__header">
      <p class="pricing-estimator__eyebrow">
        <span aria-hidden="true"></span>
        {copy.eyebrow}
      </p>
      <div class="pricing-estimator__introduction">
        <h2>{copy.title}</h2>
        <p>{copy.introduction}</p>
      </div>
    </header>

    <div class="pricing-estimator__interactive">
      <fieldset class="pricing-estimator__options">
        <legend>{copy.optionsLabel}</legend>
        <ul>
          {
            copy.engagements.map((engagement) => (
              <li>
                <button
                  type="button"
                  aria-controls="pricing-result"
                  aria-pressed="false"
                  data-pricing-option={`pricing-template-${engagement.id}`}
                >
                  <span>{engagement.index}</span>
                  <span>{engagement.label}</span>
                  <span aria-hidden="true">↘</span>
                </button>
              </li>
            ))
          }
        </ul>
      </fieldset>

      <section
        class="pricing-estimator__result"
        id="pricing-result"
        aria-label={copy.resultLabel}
        data-pricing-result
      >
        <div class="pricing-estimator__neutral">
          <p>{copy.neutral.eyebrow}</p>
          <h3>{copy.neutral.title}</h3>
          <span>{copy.neutral.body}</span>
        </div>
      </section>
    </div>

    <p class="pricing-estimator__announcement" role="status" aria-live="polite" aria-atomic="true">
    </p>

    <div hidden aria-hidden="true">
      {
        copy.engagements.map((engagement) => (
          <template id={`pricing-template-${engagement.id}`}>
            <PricingResult engagement={engagement} />
          </template>
        ))
      }
    </div>

    <noscript>
      <style is:inline>
        .pricing-estimator__interactive { display: none !important; }
      </style>
      <div class="pricing-estimator__fallback">
        <h3>{copy.noScriptTitle}</h3>
        {
          copy.engagements.map((engagement) => (
            <div class="pricing-estimator__fallback-result">
              <PricingResult engagement={engagement} />
            </div>
          ))
        }
      </div>
    </noscript>
  </div>
</section>

<style>
  .pricing-estimator {
    background: var(--color-neutral);
    color: var(--color-primary);
    padding: clamp(72px, 9vw, 128px) clamp(20px, 3.34vw, 48px);
  }

  .pricing-estimator__inner {
    display: grid;
    gap: clamp(48px, 7vw, 96px);
    margin-inline: auto;
    max-width: 1344px;
    min-width: 0;
  }

  .pricing-estimator__header {
    display: grid;
    gap: 36px;
  }

  .pricing-estimator__eyebrow {
    align-items: center;
    display: flex;
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: var(--type-label-sm-weight);
    gap: 12px;
    letter-spacing: var(--type-label-sm-letter-spacing);
    line-height: 1.3;
    text-transform: uppercase;
  }

  .pricing-estimator__eyebrow span {
    background: currentColor;
    height: 1px;
    width: 34px;
  }

  .pricing-estimator__introduction {
    display: grid;
    gap: 24px;
  }

  h2 {
    font-size: clamp(3.5rem, 7.2vw, 6.5rem);
    font-weight: 600;
    letter-spacing: -0.065em;
    line-height: 0.88;
    max-width: 980px;
    overflow-wrap: anywhere;
  }

  .pricing-estimator__introduction > p {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.5;
    max-width: 620px;
  }

  .pricing-estimator__interactive {
    display: grid;
    gap: clamp(28px, 4vw, 64px);
    min-width: 0;
  }

  .pricing-estimator__options {
    border: 0;
    margin: 0;
    min-width: 0;
    padding: 0;
  }

  .pricing-estimator__options legend {
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: var(--type-label-sm-weight);
    letter-spacing: var(--type-label-sm-letter-spacing);
    line-height: 1.3;
    padding: 0 0 16px;
    text-transform: uppercase;
  }

  .pricing-estimator__options ul {
    border-bottom: 1px solid var(--color-line);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pricing-estimator__options button {
    align-items: center;
    background: transparent;
    border: 0;
    border-top: 1px solid var(--color-line);
    color: inherit;
    cursor: pointer;
    display: grid;
    gap: 12px;
    grid-template-columns: 28px minmax(0, 1fr) 20px;
    min-height: 72px;
    padding: 12px 4px;
    text-align: left;
    transition: color var(--transition-fast), padding-inline var(--transition-fast);
    width: 100%;
  }

  .pricing-estimator__options button > span:first-child,
  .pricing-estimator__options button > span:last-child {
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    letter-spacing: var(--type-label-sm-letter-spacing);
  }

  .pricing-estimator__options button > span:nth-child(2) {
    font-size: clamp(1.125rem, 1.8vw, 1.5rem);
    font-weight: 550;
    letter-spacing: -0.02em;
    line-height: 1.15;
    overflow-wrap: anywhere;
  }

  .pricing-estimator__options button > span:last-child {
    color: var(--color-secondary);
    font-size: 1rem;
    text-align: right;
  }

  .pricing-estimator__options button:hover {
    padding-inline: 10px;
  }

  .pricing-estimator__options button[aria-pressed='true'] {
    box-shadow: inset 3px 0 var(--color-primary);
    color: var(--color-primary);
    padding-inline: 10px;
  }

  .pricing-estimator__options button[aria-pressed='true'] > span:nth-child(2) {
    font-weight: 650;
  }

  .pricing-estimator__options button[aria-pressed='true'] > span:last-child {
    color: currentColor;
  }

  .pricing-estimator__result,
  .pricing-estimator__fallback-result {
    background: var(--color-surface-inverse);
    color: var(--color-on-primary);
    min-width: 0;
    padding: clamp(28px, 4vw, 56px);
  }

  .pricing-estimator__result {
    min-height: clamp(420px, 62vw, 760px);
  }

  .pricing-estimator__neutral {
    display: flex;
    flex-direction: column;
    gap: 18px;
    height: 100%;
    justify-content: center;
    max-width: 520px;
    min-height: 360px;
  }

  .pricing-estimator__neutral p {
    color: var(--color-tertiary);
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: var(--type-label-sm-weight);
    letter-spacing: var(--type-label-sm-letter-spacing);
    text-transform: uppercase;
  }

  .pricing-estimator__neutral h3,
  .pricing-estimator__fallback > h3 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.055em;
    line-height: 0.95;
  }

  .pricing-estimator__neutral span {
    color: color-mix(in srgb, var(--color-on-primary) 70%, transparent);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.5;
  }

  .pricing-estimator__announcement {
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    width: 1px;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .pricing-estimator__fallback {
    display: grid;
    gap: 28px;
  }

  .pricing-estimator__fallback-result {
    margin-top: 20px;
  }

  @media (min-width: 901px) {
    .pricing-estimator__header {
      grid-template-columns: minmax(220px, 0.35fr) minmax(0, 1fr);
    }

    .pricing-estimator__introduction {
      justify-items: start;
    }

    .pricing-estimator__introduction > p {
      justify-self: end;
      width: min(100%, 620px);
    }

    .pricing-estimator__interactive {
      align-items: start;
      grid-template-columns: minmax(280px, 0.72fr) minmax(0, 1.5fr);
    }

    .pricing-estimator__result {
      min-height: 760px;
    }
  }

  @media (max-width: 700px) {
    .pricing-estimator__eyebrow {
      gap: 9px;
    }

    .pricing-estimator__eyebrow span {
      width: 24px;
    }

    h2 {
      font-size: clamp(3.25rem, 15vw, 4.25rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-estimator__options button {
      transition: none;
    }
  }
</style>
