---
import { pricingEstimatorCopy } from '../copy';

type Engagement = (typeof pricingEstimatorCopy.engagements)[number];

interface Props {
  engagement: Engagement;
}

const { engagement } = Astro.props;
---

<article class="pricing-result">
  <header class="pricing-result__header">
    <p class="pricing-result__eyebrow">{pricingEstimatorCopy.resultEyebrow}</p>
    <h3>{engagement.label}</h3>
    <p class="pricing-result__range" data-pricing-range>{engagement.range}</p>
  </header>

  <dl class="pricing-result__details">
    <div>
      <dt>{pricingEstimatorCopy.detailLabels.fit}</dt>
      <dd>{engagement.fit}</dd>
    </div>
    <div>
      <dt>{pricingEstimatorCopy.detailLabels.boundary}</dt>
      <dd>{engagement.boundary}</dd>
    </div>
  </dl>

  <p class="pricing-result__service">{pricingEstimatorCopy.serviceScope}</p>

  <div class="pricing-result__assumptions">
    <h4>{pricingEstimatorCopy.detailLabels.assumptions}</h4>
    <ul>
      {pricingEstimatorCopy.assumptions.map((assumption) => <li>{assumption}</li>)}
    </ul>
  </div>

  <footer class="pricing-result__footer">
    <p>{pricingEstimatorCopy.qualifier}</p>
    <a href={pricingEstimatorCopy.action.href}>
      <span>{pricingEstimatorCopy.action.label}</span>
      <span aria-hidden="true">{pricingEstimatorCopy.action.suffix}</span>
    </a>
  </footer>
</article>

<style>
  .pricing-result {
    display: flex;
    flex-direction: column;
    gap: clamp(28px, 3vw, 44px);
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .pricing-result__header {
    border-bottom: 1px solid color-mix(in srgb, var(--color-on-primary) 22%, transparent);
    display: grid;
    gap: 12px;
    padding-bottom: clamp(24px, 3vw, 40px);
  }

  .pricing-result__eyebrow,
  dt,
  h4 {
    color: color-mix(in srgb, var(--color-on-primary) 62%, transparent);
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: var(--type-label-sm-weight);
    letter-spacing: var(--type-label-sm-letter-spacing);
    line-height: 1.35;
    text-transform: uppercase;
  }

  h3 {
    font-size: clamp(2rem, 4.2vw, 4rem);
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 0.95;
  }

  .pricing-result__range {
    color: var(--color-tertiary);
    font-size: clamp(3.25rem, 7vw, 6.5rem);
    font-weight: 600;
    letter-spacing: -0.07em;
    line-height: 0.88;
    margin-top: clamp(12px, 2vw, 24px);
  }

  .pricing-result__details {
    display: grid;
    gap: 24px;
    margin: 0;
  }

  .pricing-result__details > div {
    border-top: 1px solid color-mix(in srgb, var(--color-on-primary) 22%, transparent);
    display: grid;
    gap: 12px;
    padding-top: 12px;
  }

  dd {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.5;
    margin: 0;
  }

  .pricing-result__service {
    font-size: clamp(1.15rem, 1.7vw, 1.45rem);
    font-weight: 550;
    letter-spacing: -0.02em;
    line-height: 1.35;
    max-width: 42rem;
  }

  .pricing-result__assumptions {
    border-top: 1px solid color-mix(in srgb, var(--color-on-primary) 22%, transparent);
    padding-top: 12px;
  }

  .pricing-result__assumptions ul {
    display: grid;
    gap: 10px;
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
  }

  .pricing-result__assumptions li {
    padding-left: 18px;
    position: relative;
  }

  .pricing-result__assumptions li::before {
    color: var(--color-tertiary);
    content: '—';
    inset: 0 auto auto 0;
    position: absolute;
  }

  .pricing-result__footer {
    align-items: end;
    border-top: 1px solid color-mix(in srgb, var(--color-on-primary) 22%, transparent);
    display: grid;
    gap: 24px;
    padding-top: 16px;
  }

  .pricing-result__footer p {
    color: color-mix(in srgb, var(--color-on-primary) 70%, transparent);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.015em;
    line-height: 1.55;
    max-width: 42rem;
  }

  .pricing-result__footer a {
    align-items: center;
    border-bottom: 1px solid currentColor;
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    justify-content: space-between;
    letter-spacing: 0.025em;
    min-height: 48px;
    text-decoration: none;
    transition: padding-inline var(--transition-fast);
    width: min(100%, 300px);
  }

  .pricing-result__footer a span:last-child {
    color: var(--color-tertiary);
    font-size: 1rem;
  }

  .pricing-result__footer a:hover {
    padding-inline: 8px;
  }

  @media (min-width: 900px) {
    .pricing-result__details,
    .pricing-result__footer {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .pricing-result__footer a {
      justify-self: end;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-result__footer a {
      transition: none;
    }
  }
</style>
