---
type Variant = 'default' | 'raised' | 'inverse';

interface Props {
  variant?: Variant;
  label?: string;
  class?: string;
}

const { variant = 'default', label, class: className = '' } = Astro.props;
---

<section class:list={['panel', `panel--${variant}`, className]}>
  {label && <p class="panel__label">{label}</p>}
  <div class="panel__body">
    <slot />
  </div>
</section>

<style>
  .panel {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--panel-radius);
    color: var(--color-primary);
    padding: var(--panel-padding);
  }

  .panel--raised {
    background: var(--color-surface-raised);
  }

  .panel--inverse {
    background: var(--panel-inverse-background);
    border-color: color-mix(in srgb, var(--panel-inverse-background) 80%, var(--color-line));
    color: var(--panel-inverse-foreground);
  }

  .panel__label {
    border-bottom: 1px solid currentColor;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: var(--type-label-sm-weight);
    letter-spacing: var(--type-label-sm-letter-spacing);
    line-height: var(--type-label-sm-line-height);
    margin-bottom: var(--space-lg);
    opacity: 0.76;
    padding-bottom: var(--space-sm);
    text-transform: uppercase;
  }

  .panel--inverse .panel__label {
    color: var(--color-on-primary);
  }

  .panel__body :global(> * + *) {
    margin-top: var(--space-md);
  }
</style>
