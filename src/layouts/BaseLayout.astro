---
import Header from '../components/Header.astro';
import { accessibilityCopy, metaCopy } from '../copy';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  headerVariant?: 'overlay' | 'paper';
}

const {
  title = metaCopy.title,
  description = metaCopy.description,
  headerVariant = 'paper',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600;700&family=Inter:wght@400;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">{accessibilityCopy.skipLink}</a>
    <Header variant={headerVariant} />
    <main id="content">
      <slot />
    </main>
  </body>
</html>
