---
import BaseLayout from "../layouts/BaseLayout.astro";
import { contactPageCopy } from "../copy";
---

<BaseLayout
  title={contactPageCopy.metaTitle}
  description={contactPageCopy.metaDescription}
>
  <section class="placeholder-page" aria-labelledby="contact-title">
    <p class="placeholder-page__eyebrow">{contactPageCopy.eyebrow}</p>
    <h1 id="contact-title">{contactPageCopy.title}</h1>
    <p>{contactPageCopy.body}</p>
    <a href={contactPageCopy.returnHome.href}>
      {contactPageCopy.returnHome.label}
      <span aria-hidden="true">{contactPageCopy.returnHome.suffix}</span>
    </a>
  </section>
</BaseLayout>

<style>
  .placeholder-page {
    margin-inline: auto;
    max-width: 900px;
    min-height: calc(100svh - 88px);
    padding: clamp(72px, 12vw, 160px) clamp(20px, 5vw, 48px);
  }

  .placeholder-page__eyebrow {
    color: var(--color-secondary);
    font-family: var(--font-mono);
    font-size: var(--type-label-md-size);
    letter-spacing: var(--type-label-md-letter-spacing);
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 7rem);
    letter-spacing: -0.06em;
    line-height: 0.92;
    margin-top: 28px;
  }

  .placeholder-page > p:not(.placeholder-page__eyebrow) {
    font-size: clamp(1rem, 2vw, 1.25rem);
    margin-top: 32px;
  }

  a {
    border-bottom: 1px solid currentColor;
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    gap: 12px;
    margin-top: 40px;
    min-height: 44px;
    text-decoration: none;
  }
</style>
