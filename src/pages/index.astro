---
import BaseLayout from "../layouts/BaseLayout.astro";
import AIProductDelivery from "../components/AIProductDelivery.astro";
import Capabilities from "../components/Capabilities.astro";
import ContactCta from "../components/ContactCta.astro";
import FeaturedWork from "../components/FeaturedWork.astro";
import Hero from "../components/Hero.astro";
import PricingEstimator from "../components/PricingEstimator.astro";
---

<BaseLayout headerVariant="overlay">
  <div data-home-motion>
    <Hero />
    <FeaturedWork />
    <Capabilities />
    <AIProductDelivery />
    <PricingEstimator />
    <ContactCta />
  </div>
</BaseLayout>

<script>
  import { initHomeMotion } from '../scripts/home-motion';
  import { initPricingEstimator } from '../scripts/pricing-estimator';

  const disposeHomeMotion = initHomeMotion();
  const disposePricingEstimator = initPricingEstimator();
  const disposePageRuntime = () => {
    disposeHomeMotion();
    disposePricingEstimator();
  };

  document.addEventListener('astro:before-swap', disposePageRuntime, { once: true });
  window.addEventListener('pagehide', (event) => {
    if (!event.persisted) disposePageRuntime();
  });
</script>
