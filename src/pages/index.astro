---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Chip from '../components/Chip.astro';
import FormField from '../components/FormField.astro';
import Panel from '../components/Panel.astro';
import SectionHeader from '../components/SectionHeader.astro';

const replacements = [
  {
    label: 'old system:',
    title: 'Spreadsheet gravity',
    description: 'Pricing, approvals, and reporting trapped in fragile tabs with one terrified owner.',
    status: 'old way detected',
  },
  {
    label: 'workflow:',
    title: 'Manual relay teams',
    description: 'People copying information between tools because the process never learned to move itself.',
    status: 'replacement pending',
  },
  {
    label: 'interface:',
    title: 'Technically working pain',
    description: 'Products that function on paper, but make every user feel like they are negotiating with a cupboard.',
    status: 'repair advised',
  },
];

const products = [
  {
    label: 'service: repair',
    title: 'Interface repair',
    description: 'For products that technically work, but feel painful, cluttered, or unclear.',
    status: 'useful when redesigned',
  },
  {
    label: 'service: replacement',
    title: 'Workflow tools',
    description: 'Custom systems for replacing forms, spreadsheets, inbox rituals, and approval archaeology.',
    status: 'duplicate entry retired',
  },
  {
    label: 'service: product',
    title: 'Product systems',
    description: 'Designed and engineered software with proper states, logic, content, and maintainable interfaces.',
    status: 'built properly',
  },
];

const process = [
  ['01', 'Diagnose the old way', 'Map the workaround, the people keeping it alive, and the cost of pretending it is fine.'],
  ['02', 'Design the replacement', 'Turn messy operational knowledge into clear flows, screens, states, and decisions.'],
  ['03', 'Build the useful thing', 'Ship the system with restrained interface design, clean engineering, and fewer future apologies.'],
  ['04', 'Retire what remains', 'Document the handover, remove duplicate effort, and make the old process boringly unnecessary.'],
];
---

<BaseLayout>
  <header class="site-header container">
    <a class="brand" href="/" aria-label="Obsolete home">
      <span class="brand__mark" aria-hidden="true"></span>
      Obsolete
    </a>
    <nav aria-label="Primary navigation">
      <a href="#replace">Replace</a>
      <a href="#work">Work</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <main id="content">
    <section class="hero container" aria-labelledby="hero-title">
      <div class="hero__copy flow">
        <Chip tone="signal">status: old way detected</Chip>
        <h1 id="hero-title" class="display">Make the old way obsolete.</h1>
        <p class="body-lg muted">Beautiful software for retiring bad systems, replacing painful workflows, and repairing interfaces that have outstayed their welcome.</p>
        <div class="hero__actions">
          <Button href="#contact">Show us the old way</Button>
          <Button href="#work" variant="ghost">Inspect work</Button>
        </div>
      </div>

      <Panel variant="inverse" label="system: replacement pending" class="hero__panel">
        <dl class="system-readout">
          <div>
            <dt>Input</dt>
            <dd>Bad interface, manual workaround, spreadsheet with authority issues.</dd>
          </div>
          <div>
            <dt>Action</dt>
            <dd>Diagnose, reduce, design, build, retire.</dd>
          </div>
          <div>
            <dt>Result</dt>
            <dd>Useful software. Fewer rituals. Less avoidable panic.</dd>
          </div>
        </dl>
      </Panel>
    </section>

    <section id="replace" class="section container">
      <SectionHeader
        eyebrow="what we replace"
        title="Outdated tools are not charming. They are just expensive in disguise."
        description="Obsolete turns operational mess into clear, maintainable product systems. The humour stays in the labels; the work stays serious."
      />
      <div class="card-grid card-grid--three">
        {replacements.map((item) => <Card {...item} />)}
      </div>
    </section>

    <section id="work" class="section section--split container">
      <SectionHeader
        eyebrow="what we make"
        title="Designed like a product. Built like it has to last."
        description="We care about interface, product logic, engineering quality, and the quiet removal of unnecessary complexity."
      />
      <div class="card-grid card-grid--three">
        {products.map((item) => <Card {...item} />)}
      </div>
    </section>

    <section class="section container">
      <div class="process-shell">
        <SectionHeader
          eyebrow="how we work"
          title="A calm replacement procedure."
          description="No innovation theatre. No decorative software. Just enough process to understand the old way and remove it properly."
        />
        <ol class="process-list">
          {process.map(([number, title, description]) => (
            <li>
              <span>{number}</span>
              <div>
                <h3>{title}</h3>
                <p>{description}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section container">
      <Panel label="selected replacement record" class="case-study">
        <div class="case-study__heading">
          <Chip>client: internal operations</Chip>
          <h2 class="headline-lg">Goodbye, approval chasing.</h2>
        </div>
        <div class="case-study__grid">
          <div>
            <p class="eyebrow">Old system</p>
            <p>Spreadsheet with 14 tabs, three pricing interpretations, and one owner everyone hoped was online.</p>
          </div>
          <div>
            <p class="eyebrow">Replacement</p>
            <p>Custom quoting tool with approval states, pricing logic, and a record of who did what.</p>
          </div>
          <div>
            <p class="eyebrow">Retired</p>
            <p>Duplicate entry, version confusion, approval chasing, and avoidable panic.</p>
          </div>
        </div>
      </Panel>
    </section>

    <section id="contact" class="section section--contact container">
      <div>
        <SectionHeader
          eyebrow="contact cta"
          title="Submit an old way for inspection."
          description="Tell us what needs replacing. We will inspect the mess, name the useful replacement, and avoid calling it transformation."
        />
      </div>
      <Panel variant="raised" label="form: old way intake">
        <form class="contact-form" method="post">
          <FormField id="needs-replacing" label="What needs replacing?" placeholder="Spreadsheet, workflow, product, interface..." required />
          <FormField id="pain" label="Where does it hurt?" type="textarea" placeholder="Duplicate work, unclear states, everyone waiting for Martin..." required />
          <FormField id="email" label="Who should we reply to?" type="email" placeholder="name@example.com" required />
          <Button type="submit">Send old way</Button>
          <p class="form-note">result: process retired, pending inspection</p>
        </form>
      </Panel>
    </section>
  </main>

  <footer class="site-footer container">
    <p>Obsolete — beautiful software for retiring bad systems.</p>
    <Chip>version: alpha</Chip>
  </footer>
</BaseLayout>

<style>
  .site-header {
    align-items: center;
    border-bottom: 1px solid var(--color-line);
    display: flex;
    justify-content: space-between;
    min-height: 76px;
  }

  .brand {
    align-items: center;
    display: inline-flex;
    font-size: 1rem;
    font-weight: 600;
    gap: var(--space-sm);
    letter-spacing: -0.03em;
    text-decoration: none;
  }

  .brand__mark {
    background: var(--color-primary);
    border-radius: var(--radius-sm);
    display: inline-block;
    height: 14px;
    position: relative;
    width: 14px;
  }

  .brand__mark::after {
    background: var(--color-tertiary);
    content: '';
    height: 4px;
    inset: 5px -5px auto auto;
    position: absolute;
    width: 10px;
  }

  nav {
    align-items: center;
    display: flex;
    gap: var(--space-md);
  }

  nav a {
    color: var(--color-secondary);
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    letter-spacing: var(--type-label-sm-letter-spacing);
    text-decoration: none;
    text-transform: uppercase;
  }

  nav a:hover {
    color: var(--color-primary);
  }

  .hero {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.75fr);
    min-height: calc(100svh - 76px);
    padding-block: var(--space-section);
  }

  .hero__copy {
    align-self: center;
    max-width: 920px;
    --flow-space: var(--space-lg);
  }

  .hero__actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    padding-top: var(--space-md);
  }

  .hero__panel {
    align-self: end;
  }

  .system-readout {
    display: grid;
    gap: var(--space-lg);
    margin: 0;
  }

  .system-readout div {
    border-top: 1px solid color-mix(in srgb, var(--color-on-primary) 20%, transparent);
    padding-top: var(--space-md);
  }

  .system-readout dt {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    letter-spacing: var(--type-label-sm-letter-spacing);
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
  }

  .system-readout dd {
    margin: 0;
  }

  .section {
    padding-block: var(--space-section);
  }

  .section--split {
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .card-grid {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }

  .card-grid--three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .process-shell {
    background: var(--color-primary);
    border-radius: var(--radius-lg);
    color: var(--color-on-primary);
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: minmax(0, 0.82fr) minmax(320px, 1fr);
    padding: var(--space-xl);
  }

  .process-shell :global(.eyebrow),
  .process-shell :global(.muted) {
    color: color-mix(in srgb, var(--color-on-primary) 72%, transparent);
  }

  .process-list {
    display: grid;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .process-list li {
    border-top: 1px solid color-mix(in srgb, var(--color-on-primary) 20%, transparent);
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: 48px 1fr;
    padding-block: var(--space-lg);
  }

  .process-list span {
    color: var(--color-tertiary);
    font-family: var(--font-mono);
    font-size: var(--type-label-md-size);
    letter-spacing: var(--type-label-md-letter-spacing);
  }

  .process-list h3 {
    font-size: var(--type-body-lg-size);
    letter-spacing: var(--type-body-lg-letter-spacing);
    line-height: var(--type-body-lg-line-height);
    margin-bottom: var(--space-xs);
  }

  .process-list p {
    color: color-mix(in srgb, var(--color-on-primary) 74%, transparent);
  }

  .case-study {
    padding: var(--space-xl);
  }

  .case-study__heading {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .case-study__grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .case-study__grid > div {
    border-left: 1px solid var(--color-line);
    padding-left: var(--space-lg);
  }

  .case-study__grid p:last-child {
    color: var(--color-secondary);
    margin-top: var(--space-md);
  }

  .section--contact {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: minmax(0, 0.8fr) minmax(320px, 1fr);
  }

  .contact-form {
    display: grid;
    gap: var(--space-lg);
  }

  .contact-form :global(.button) {
    justify-self: start;
  }

  .form-note {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    letter-spacing: var(--type-label-sm-letter-spacing);
    text-transform: uppercase;
  }

  .site-footer {
    align-items: center;
    border-top: 1px solid var(--color-line);
    color: var(--color-secondary);
    display: flex;
    gap: var(--space-md);
    justify-content: space-between;
    padding-block: var(--space-lg);
  }

  @media (max-width: 900px) {
    .hero,
    .process-shell,
    .section--contact {
      grid-template-columns: 1fr;
    }

    .card-grid--three,
    .case-study__grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .site-header,
    .site-footer {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      padding-block: var(--space-md);
    }

    nav {
      flex-wrap: wrap;
    }

    .process-shell,
    .case-study {
      padding: var(--space-lg);
    }
  }
</style>
