---
import { Image } from 'astro:assets';
import craftAppliedImage from '../assets/img/craft-applied-desktop.jpg';
import triggerDevImage from '../assets/img/trigger-dev-desktop.jpg';
import workHeroImage from '../assets/img/obsolete/mali2.png';
import BaseLayout from '../layouts/BaseLayout.astro';
import { workPageCopy as copy } from '../copy';

const projectImages = {
  'craft-applied': craftAppliedImage,
  'trigger-dev': triggerDevImage,
} as const;
---

<BaseLayout
  title={copy.metaTitle}
  description={copy.metaDescription}
  image={craftAppliedImage.src}
  imageAlt={copy.projects[0].imageAlt}
>
  <header class="work-index__hero">
    <div class="work-index__inner work-index__hero-grid">
      <div class="work-index__hero-copy">
        <p class="work-index__eyebrow">
          <span aria-hidden="true"></span>
          {copy.eyebrow}
        </p>
        <div class="work-index__heading">
          <h1>{copy.title}</h1>
          <p>{copy.introduction}</p>
        </div>
      </div>

      <figure class="work-index__artwork">
        <div class="work-index__art">
          <Image
            src={workHeroImage}
            alt=""
            aria-hidden="true"
            layout="full-width"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <figcaption>
          <span>Visual study / 02</span>
          <span>Ideas → systems</span>
        </figcaption>
      </figure>
    </div>
  </header>

  <section class="work-index__projects" aria-label="Published case studies">
    <div class="work-index__inner">
      {copy.projects.map((project) => (
        <a
          class="project"
          href={project.href}
          aria-label={`${project.action}: ${project.title}`}
          style={`--project-media-background: ${project.id === 'trigger-dev' ? '#101114' : '#00853e'}`}
        >
          <div class="project__rail">
            <span>{project.index}</span>
            <span>Design + development</span>
          </div>

          <div class="project__heading">
            <h2>{project.title}</h2>
            <div>
              <p class="project__statement">{project.statement}</p>
              <p class="project__summary">{project.summary}</p>
            </div>
          </div>

          <figure>
            <Image
              src={projectImages[project.id]}
              alt={project.imageAlt}
              loading={project.index === '01' ? 'eager' : 'lazy'}
              decoding="async"
            />
            <figcaption>
              <span>{project.action}</span>
              <span aria-hidden="true">→</span>
            </figcaption>
          </figure>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .work-index__hero,
  .work-index__projects {
    padding-inline: clamp(20px, 3.34vw, 48px);
  }

  .work-index__inner {
    margin-inline: auto;
    max-width: 1344px;
  }

  .work-index__hero {
    padding-block: clamp(32px, 4vw, 64px) clamp(48px, 6vw, 88px);
  }

  .work-index__hero-grid {
    display: grid;
    gap: clamp(40px, 6vw, 96px);
    grid-template-columns: minmax(0, 0.95fr) minmax(420px, 0.75fr);
  }

  .work-index__hero-copy {
    border-top: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    min-height: clamp(620px, calc(100svh - 152px), 820px);
    padding-top: 14px;
  }

  .work-index__eyebrow {
    align-items: center;
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    gap: 12px;
    letter-spacing: 0.055em;
    text-transform: uppercase;
  }

  .work-index__eyebrow span {
    background: var(--color-tertiary);
    height: 1px;
    width: 34px;
  }

  .work-index__heading {
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  h1 {
    font-size: clamp(4.5rem, 7vw, 7rem);
    font-weight: 600;
    letter-spacing: -0.072em;
    line-height: 0.82;
    margin-top: clamp(88px, 11vw, 156px);
    max-width: 760px;
  }

  .work-index__heading > p {
    border-top: 1px solid var(--color-line);
    color: var(--color-secondary);
    font-size: clamp(1.125rem, 1.7vw, 1.375rem);
    line-height: 1.5;
    margin-top: auto;
    max-width: 460px;
    padding-top: 20px;
  }

  .work-index__artwork {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    margin: 0;
    min-height: clamp(620px, calc(100svh - 152px), 820px);
    overflow: hidden;
  }

  .work-index__art {
    min-height: 0;
    overflow: hidden;
  }

  .work-index__art img {
    height: 100%;
    object-fit: cover;
    object-position: center;
    width: 100%;
  }

  .work-index__artwork figcaption {
    align-items: center;
    background: var(--color-surface-raised);
    border-top: 1px solid var(--color-line);
    display: flex;
    font-family: var(--font-mono);
    font-size: var(--type-label-sm-size);
    font-weight: var(--type-label-sm-weight);
    justify-content: space-between;
    letter-spacing: var(--type-label-sm-letter-spacing);
    min-height: 52px;
    padding-inline: 16px;
    text-transform: uppercase;
  }

  .work-index__artwork figcaption span:last-child {
    color: var(--color-secondary);
  }

  .work-index__projects {
    background: var(--color-surface);
    border-top: 1px solid var(--color-line);
    padding-block: clamp(72px, 8vw, 120px);
  }

  .project {
    display: block;
    text-decoration: none;
  }

  .project + .project {
    margin-top: clamp(72px, 10vw, 144px);
  }

  .project__rail {
    border-top: 1px solid var(--color-line);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    justify-content: space-between;
    letter-spacing: 0.055em;
    padding-top: 14px;
    text-transform: uppercase;
  }

  .project__rail span:first-child {
    color: #a32e18;
  }

  .project__heading {
    align-items: end;
    display: grid;
    gap: clamp(48px, 8vw, 132px);
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    padding-block: clamp(52px, 7vw, 98px);
  }

  h2 {
    font-size: clamp(3.75rem, 8vw, 7.5rem);
    font-weight: 600;
    letter-spacing: -0.068em;
    line-height: 0.84;
  }

  .project__heading > div {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .project__statement {
    font-size: clamp(1.5rem, 2.6vw, 2.25rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .project__summary {
    color: var(--color-secondary);
    max-width: 520px;
  }

  .project figure {
    background: var(--project-media-background);
    border: 1px solid var(--color-line);
    margin: 0;
    overflow: hidden;
  }

  .project figure img {
    height: auto;
    transition: transform 400ms ease;
    width: 100%;
  }

  .project figcaption {
    align-items: center;
    background: var(--color-surface-raised);
    border-top: 1px solid var(--color-line);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    justify-content: space-between;
    letter-spacing: 0.025em;
    min-height: 52px;
    padding-inline: 16px;
  }

  .project figcaption span:last-child {
    color: var(--color-tertiary);
    font-size: 1rem;
    transition: transform var(--transition-fast);
  }

  .project:hover figure img {
    transform: scale(1.012);
  }

  .project:hover figcaption span:last-child {
    transform: translateX(5px);
  }

  @media (max-width: 900px) {
    .work-index__hero-grid {
      gap: 64px;
      grid-template-columns: 1fr;
    }

    .work-index__hero-copy {
      min-height: 600px;
    }

    .work-index__artwork {
      min-height: 0;
    }

    .work-index__art img {
      height: auto;
    }
  }

  @media (max-width: 800px) {
    .project__heading {
      align-items: start;
      grid-template-columns: 1fr;
    }

    .project__heading > div {
      max-width: 620px;
    }
  }

  @media (max-width: 700px) {
    .work-index__hero {
      padding-top: 24px;
    }

    .work-index__hero-copy {
      min-height: 540px;
    }

    h1 {
      font-size: clamp(3.75rem, 18vw, 5.25rem);
      margin-top: 72px;
    }

    h2 {
      font-size: clamp(3.75rem, 17vw, 5rem);
    }

    .work-index__artwork figcaption {
      font-size: 0.625rem;
    }

    .project__rail span:last-child {
      text-align: right;
    }

    .project figure img {
      min-height: 300px;
      object-fit: cover;
      object-position: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project figure img,
    .project figcaption span:last-child {
      transition: none;
    }
  }
</style>
